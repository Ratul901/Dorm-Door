PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/dormdoor
# Atlas example:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dormdoor
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=http://localhost:5173

# Created automatically on backend startup if it does not exist.
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@dormdoor.com
SUPER_ADMIN_PASSWORD=Super123!
# Set true only if you need to reset an existing default super admin password.
SUPER_ADMIN_RESET_PASSWORD=false

# Optional: only needed for automated waitlist promotion emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Dorm Door <no-reply@dormdoor.local>
